# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Node modules
node_modules/

# Environment variables
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build output
.next/
out/
dist/
.drizzle/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
.pnpm/
.cache/

# VSC & OS generated
.vscode/
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Optional: ignore editor-specific settings
.idea/
*.swp

# Optional Drizzle cache (if you're generating SQL)
migrations/

# Clerk session cache (if any)
.clerk/
